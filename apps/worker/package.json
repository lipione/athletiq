{
  "name": "@athletiq/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @athletiq/shared build && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint . --max-warnings=0",
    "smoke": "NODE_ENV=test node dist/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@athletiq/shared": "workspace:*",
    "bullmq": "^5.53.2",
    "ioredis": "^5.6.1",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@athletiq/config": "workspace:*",
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4"
  }
}
