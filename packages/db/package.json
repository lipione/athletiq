  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@athletiq/config": "workspace:*",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.1"
