NODE_ENV=development
API_PORT=4000
ATHLETIQ_POSTGRES_PORT=15432
ATHLETIQ_REDIS_PORT=16379
ATHLETIQ_DATA_BACKEND=memory
DATABASE_URL=postgres://athletiq:athletiq@localhost:15432/athletiq
REDIS_URL=redis://localhost:16379
WEB_PUBLIC_API_URL=http://localhost:4000/api
ATHLETIQ_JWT_SECRET=replace-with-at-least-32-random-characters
ATHLETIQ_ACCESS_TOKEN_TTL_SECONDS=900
ATHLETIQ_REFRESH_TOKEN_TTL_SECONDS=2592000
ATHLETIQ_ALLOW_TEST_HEADERS=0
ATHLETIQ_ALLOW_INSECURE_DEV_JWT_SECRET=0
ATHLETIQ_RELEASE_SHA=local

# Production image references.
ATHLETIQ_API_IMAGE=ghcr.io/your-org/athletiq-api:replace-me
ATHLETIQ_WEB_IMAGE=ghcr.io/your-org/athletiq-web:replace-me
ATHLETIQ_WORKER_IMAGE=ghcr.io/your-org/athletiq-worker:replace-me
POSTGRES_USER=athletiq
POSTGRES_PASSWORD=replace-with-secret
POSTGRES_DB=athletiq
WEB_PORT=3000

# Observability and recovery.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_BACKEND_OTLP_ENDPOINT=https://otel-backend.example.com
OTEL_BACKEND_OTLP_HEADERS=Bearer replace-with-secret
BACKUP_BUCKET=s3://athletiq-backups/example
BACKUP_RETENTION_DAYS=30
